{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "启动 PulseGrid 预览服务器",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\.vscode\\start-server.ps1"
            ],
            "isBackground": true,
            "problemMatcher": {
                "owner": "pulsegrid",
                "pattern": {
                    "regexp": ".*"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "脉冲音格预览任务正在启动",
                    "endsPattern": "预览服务已启动："
                }
            },
            "presentation": {
                "reveal": "silent",
                "panel": "dedicated"
            }
        }
    ]
}
