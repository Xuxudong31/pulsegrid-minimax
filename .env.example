# 复制为 .env 后再填写本机密钥。不要提交真实密钥。
MINIMAX_API_KEY=在这里填写你的_MiniMax_API_Key
MINIMAX_MODEL=MiniMax-M3
MINIMAX_BASE_URL=https://api.minimaxi.com/v1

# 数据后台。本地可不填 DATABASE_URL，此时使用临时内存统计。
ADMIN_PASSWORD=请设置一个只有你知道的后台密码
ADMIN_SESSION_SECRET=请设置一段随机长字符串
DATABASE_URL=
ANALYTICS_TIME_ZONE=Asia/Shanghai

# 本地预览配置
HOST=127.0.0.1
PORT=4173
